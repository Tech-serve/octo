# Скопируй этот файл в .env (в папке server/) и заполни OCTO_API_TOKEN.
# cp .env.example .env  (или скопируй вручную и переименуй)

# Порт HTTP-сервера бэкенда
PORT=3000

# CORS: разрешённый origin фронтенда (* — любой)
CORS_ORIGIN=*

# Локальный API Octo Browser (запуск/остановка профилей) — не менять
OCTO_API=http://127.0.0.1:58888/api/profiles

# Облачное API Octo Browser (список профилей) — обычно не менять
OCTO_CLOUD_API=https://app.octobrowser.net/api/v2/automation

# API-токен Octo (мастер-аккаунт). ОБЯЗАТЕЛЬНО ЗАПОЛНИТЬ.
# Взять: веб-кабинет app.octobrowser.net -> настройки -> API.
OCTO_API_TOKEN=

# Максимум одновременно выполняемых задач (остальные ждут в очереди)
MAX_CONCURRENT=30

# Пауза между постами ОДНОГО профиля (минуты)
POST_DELAY_MIN=1
POST_DELAY_MAX=3

# Разброс старта фейков в режиме 2 (минуты, окно)
MODE2_SPREAD=60

# Пауза между репликами диалога в режиме 3 (минуты)
MODE3_GAP_MIN=5
MODE3_GAP_MAX=30

# Минимальный зазор между задачами одного фейка (минуты) — умное окно
MIN_FAKE_GAP_MIN=5
MIN_FAKE_GAP_MAX=10

# Лимит одинаковых постов на один фейк
MAX_SAME_PER_PROFILE=10

# Блокировать загрузку видео на страницах (картинки грузятся)
BLOCK_VIDEO=true

# Папки (по умолчанию внутри server/)
LOG_DIR=logs

# Запускать браузер в headless-режиме (для Octo — оставить false)
HEADLESS=false

# Таймауты (мс)
NAV_TIMEOUT=60000
SELECTOR_TIMEOUT=15000

# ── Авторизация (для встраивания в таск-менеджер) ─────────────────────
# Выключено (по умолчанию) — бот работает standalone, без входа, как есть.
# Включить, когда бот встроен вкладкой в кабинет баера.
AUTH_ENABLED=false

# Общий секрет с таск-менеджером (тот же GENERATOR_SSO_SECRET, что в .env ТМ).
# Им бот проверяет входящий одноразовый SSO-токен.
GENERATOR_SSO_SECRET=

# Свой секрет бота для сессионной куки (НЕ равен GENERATOR_SSO_SECRET).
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_JWT_SECRET=

# Домен куки, чтобы она жила и в iframe (напр. .vroo.it.com). Пусто — хост как есть.
COOKIE_DOMAIN=

# secure + SameSite=None (нужно для iframe по HTTPS). Локально по http — false.
COOKIE_SECURE=false

# Домен таск-менеджера, которому разрешено встраивать бота в iframe
# (напр. https://tm.vroo.it.com). Пусто — заголовок не ставится.
FRAME_ANCESTOR=

# aud/iss SSO-токена (по умолчанию как у генератора — обычно менять не нужно).
SSO_AUDIENCE=generator
SSO_ISSUER=taskmanager
